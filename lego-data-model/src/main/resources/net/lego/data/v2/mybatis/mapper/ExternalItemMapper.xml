<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.lego.data.v2.mybatis.mapper.ExternalItemMapper">
    <resultMap type="net.lego.data.v2.dto.ExternalItem" id="externalItemResultMap">
        <result column="external_item_id" property="externalItemId"/>
        <result column="external_number" property="externalNumber"/>
        <result column="external_unique_id" property="uniqueId"/>
        <result column="external_item_type" property="itemType"/>
        <result column="external_name" property="name" />
        <result column="external_url" property="url"/>
        <result column="external_service_id" property="serviceId"/>
        <result column="external_category_id" property="categoryId"/>
        <result column="external_year_released" property="yearReleased"/>
        <association property="externalService"
                     resultMap="net.lego.data.v2.mybatis.mapper.ExternalServiceMapper.externalServiceResultMap"
                     javaType="net.lego.data.v2.dto.ExternalService">
            <id column="external_service_id" property="externalServiceId"/>
            <result column="external_service_name" property="externalServiceName"/>
            <result column="external_service_url" property="externalServiceUrl"/>
            <result column="external_service_type_id" property="externalServiceTypeId"/>
        </association>
        <association property="category"
                     resultMap="net.lego.data.v2.mybatis.mapper.CategoryMapper.categoryResultMap"
                     javaType="net.lego.data.v2.dto.Category">
            <id column="external_category_id" property="externalCategoryId"/>
            <result column="external_service_id" property="externalServiceId"/>
            <result column="category_name" property="categoryName"/>
            <result column="parent_id" property="parentId"/>
        </association>
    </resultMap>
</mapper>